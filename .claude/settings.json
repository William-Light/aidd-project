{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node -e ' *)",
      "Bash(npx tsc *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3001/)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3001/kudos)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3001/login)",
      "Bash(npx next *)",
      "Bash(cp -r src/app/\"\\(auth\\)\" app/)",
      "Bash(cp -r src/app/\"\\(main\\)\" app/)",
      "Bash(cp -r src/app/auth app/)",
      "Bash(cp src/app/layout.tsx app/layout.tsx)",
      "Bash(cp src/app/favicon.ico app/favicon.ico)",
      "Bash(Remove-Item -Recurse -Force src/app)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3001/awards\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3001/kudos\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3001/kudos/write\")",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"http://localhost:3001/login\")",
      "PowerShell(taskkill /F /IM node.exe 2>$null)",
      "Bash(curl -s -X POST https://mcp.momorph.ai/mcp -H 'x-github-token: __TRACKED_VAR__' -H 'Content-Type: application/json' -d '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"tools/call\",\"params\":{\"name\":\"get_frame\",\"arguments\":{\"fileKey\":\"9ypp4enmFmdK3YAFJLIu6C\",\"screenId\":\"GzbNeVGJHz\"}}}')",
      "Bash(node -e \"const data = require\\('fs'\\).readFileSync\\(0, 'utf8'\\); const parsed = JSON.parse\\(data\\); const frameStr = parsed.result.content[0].text; const frame = JSON.parse\\(frameStr\\).frame; console.log\\(JSON.stringify\\(frame, null, 2\\)\\);\")"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-init.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/session-state.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/usage-quota-cache-refresh.cjs\"",
            "timeout": 8
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/subagent-init.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/team-context-inject.cjs\""
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "Plan",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/takumi-after-plan-reminder.cjs\""
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-state.cjs\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/dev-rules-reminder.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/usage-quota-cache-refresh.cjs\"",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/descriptive-name.cjs\""
          }
        ]
      },
      {
        "matcher": "Bash|Glob|Grep|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/safety-guard.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/scout-block.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/privacy-block.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/skill-dedup.cjs\""
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/skill-extension-loader.cjs\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Task|TaskCreate|TaskUpdate|TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-state.cjs\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/iron-laws-guard.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/post-edit-simplify-reminder.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/plan-format-kanban.cjs\""
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/usage-context-awareness.cjs\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/task-completed-handler.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/usage-quota-cache-refresh.cjs\"",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \".claude/hooks/session-state.cjs\""
          },
          {
            "type": "command",
            "command": "node \".claude/hooks/telemetry.cjs\"",
            "timeout": 2
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node \"$CLAUDE_PROJECT_DIR\"/.claude/statusline.cjs",
    "padding": 0
  }
}
